{
  "name": "@axon/service-hub",
  "version": "0.1.0",
  "description": "Hub orchestrator service covering IU-13 through IU-17 validation scope.",
  "keywords": ["axon-flow", "iu-13", "service", "hub"],
  "type": "module",
  "main": "dist/main.cjs",
  "module": "dist/main.mjs",
  "types": "dist/main.d.ts",
  "scripts": {
    "start": "node dist/main.cjs",
    "start:dev": "nest start --watch",
    "dev": "pnpm run start:dev",
    "build": "nest build",
    "lint": "eslint --max-warnings=0 'src/**/*.ts'",
    "test": "pnpm run test:unit && pnpm run test:integration && pnpm run test:contract",
    "test:unit": "jest --config jest.config.ts --selectProjects unit",
    "test:integration": "jest --config jest.config.ts --selectProjects integration",
    "test:contract": "jest --config jest.config.ts --selectProjects contract",
    "typecheck": "tsc --build tsconfig.json",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@axon/application-plan-generation": "workspace:*",
    "@axon/infrastructure-messaging": "workspace:*",
    "@axon/logger": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.9.0"
  }
}
