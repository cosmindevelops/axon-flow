# ==============================================================================
# AXON FLOW - ENVIRONMENT CONFIGURATION
# ==============================================================================
# This file documents all environment variables used across the Axon Flow monorepo.
#
# USAGE:
#   1. Copy this file to `.env` in the repository root
#   2. Fill in the required values (marked [REQUIRED])
#   3. Optionally configure optional values (marked [OPTIONAL])
#   4. Run `pnpm validate:env` to verify your configuration
#
# PRECEDENCE:
#   - Workspace-level .env files override root .env
#   - Runtime environment variables override both
#   - See ENV_MANAGEMENT.md for full precedence documentation
#
# SECURITY:
#   - NEVER commit .env files to version control
#   - Use secret managers for production deployments (AWS Secrets Manager, etc.)
#   - Rotate sensitive credentials regularly
# ==============================================================================

# ------------------------------------------------------------------------------
# CORE APPLICATION
# ------------------------------------------------------------------------------

# [REQUIRED] Application environment mode
# Controls behavior across services and applications
# Validation: Must be one of: development, staging, production
NODE_ENV=development

# [OPTIONAL] Logging verbosity level
# Controls console and file log output detail
# Validation: Must be one of: debug, info, warn, error
# Default: info
LOG_LEVEL=info

# [OPTIONAL] Default application port
# Used by services that don't specify their own port
# Validation: Integer between 1024-65535
# Default: 3000
PORT=3000

# ------------------------------------------------------------------------------
# TURBOREPO & BUILD SYSTEM
# ------------------------------------------------------------------------------

# [OPTIONAL] Turborepo remote cache team identifier
# Enable remote caching for faster CI/CD builds
# Validation: Alphanumeric string
# See: https://turbo.build/repo/docs/core-concepts/remote-caching
TURBO_TEAM=

# [OPTIONAL] Turborepo remote cache authentication token
# Required if using Vercel remote cache
# Validation: Base64 encoded string
TURBO_TOKEN=

# [OPTIONAL] Turborepo remote cache signature key
# Used to verify cache artifacts
# Validation: Base64 encoded string, min 32 characters
TURBO_REMOTE_CACHE_SIGNATURE_KEY=

# [AUTO-SET] Continuous Integration flag
# Automatically set by CI/CD platforms
# Do not set manually - used for CI-specific behaviors
# CI=true

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION (Future - IU-5 onwards)
# ------------------------------------------------------------------------------

# [REQUIRED for services] PostgreSQL connection string
# Format: postgresql://user:password@host:port/database?options
# Validation: Must start with postgresql:// or postgres://
# Example: postgresql://axon:password@localhost:5432/axon_flow?schema=public
DATABASE_URL=

# [OPTIONAL] PostgreSQL connection pool size
# Maximum number of concurrent database connections
# Validation: Integer between 1-100
# Default: 10
DATABASE_POOL_SIZE=10

# [REQUIRED for services] Redis connection string
# Format: redis://[user:password@]host:port[/database]
# Validation: Must start with redis:// or rediss://
# Example: redis://localhost:6379/0
REDIS_URL=

# [OPTIONAL] Default Redis TTL in seconds
# Time-to-live for cached entries
# Validation: Positive integer
# Default: 3600 (1 hour)
REDIS_TTL=3600

# [OPTIONAL] Redis key prefix
# Namespace for all Redis keys to avoid collisions
# Validation: Alphanumeric with underscores/hyphens
# Default: axon_flow
REDIS_KEY_PREFIX=axon_flow

# ------------------------------------------------------------------------------
# MESSAGE BROKER (Future - IU-6 onwards)
# ------------------------------------------------------------------------------

# [REQUIRED for services] RabbitMQ connection string
# Format: amqp://user:password@host:port/vhost
# Validation: Must start with amqp:// or amqps://
# Example: amqp://axon:password@localhost:5672/
RABBITMQ_URL=

# [OPTIONAL] RabbitMQ consumer prefetch count
# Number of messages to prefetch per consumer
# Validation: Positive integer
# Default: 1
RABBITMQ_PREFETCH=1

# [OPTIONAL] RabbitMQ heartbeat interval (seconds)
# Keep-alive interval for connections
# Validation: Positive integer
# Default: 60
RABBITMQ_HEARTBEAT=60

# ------------------------------------------------------------------------------
# AUTHENTICATION & AUTHORIZATION (Future - IU-21, IU-22)
# ------------------------------------------------------------------------------

# [REQUIRED] JWT signing secret
# Used to sign and verify JWT tokens
# Validation: Minimum 32 characters, alphanumeric + special chars
# SECURITY: Generate with: openssl rand -base64 32
JWT_SECRET=

# [OPTIONAL] JWT token expiration time
# Format: Zeit/ms format (e.g., 24h, 7d, 1y)
# Validation: Must match pattern: \\d+[smhdy]
# Default: 24h
JWT_EXPIRES_IN=24h

# [OPTIONAL] JWT refresh token expiration
# Format: Zeit/ms format
# Validation: Must match pattern: \\d+[smhdy]
# Default: 7d
JWT_REFRESH_EXPIRES_IN=7d

# [OPTIONAL] Google OAuth 2.0 Client ID
# Required for Google authentication
# Validation: Ends with .apps.googleusercontent.com
# Obtain from: https://console.cloud.google.com/apis/credentials
OAUTH_GOOGLE_CLIENT_ID=

# [OPTIONAL] Google OAuth 2.0 Client Secret
# Required for Google authentication
# Validation: Alphanumeric string
OAUTH_GOOGLE_CLIENT_SECRET=

# [OPTIONAL] GitHub OAuth App Client ID
# Required for GitHub authentication
# Validation: Alphanumeric string, starts with Iv1. or Iv23.
# Obtain from: https://github.com/settings/developers
OAUTH_GITHUB_CLIENT_ID=

# [OPTIONAL] GitHub OAuth App Client Secret
# Required for GitHub authentication
# Validation: Alphanumeric string
OAUTH_GITHUB_CLIENT_SECRET=

# [OPTIONAL] OAuth callback base URL
# Base URL for OAuth redirect URIs
# Validation: Must start with http:// or https://
# Default: http://localhost:3000
OAUTH_CALLBACK_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# EXTERNAL LLM PROVIDERS (Future - IU-14 onwards)
# ------------------------------------------------------------------------------

# [OPTIONAL] Default LLM provider
# Which provider to use for AI operations
# Validation: Must be one of: openai, anthropic, gemini, bedrock, azure
# Default: openai
LLM_PROVIDER=openai

# [OPTIONAL] OpenAI API Key
# Required if LLM_PROVIDER=openai
# Validation: Starts with sk-
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# [OPTIONAL] OpenAI organization ID
# For users with multiple organizations
# Validation: Starts with org-
OPENAI_ORG_ID=

# [OPTIONAL] Anthropic API Key
# Required if LLM_PROVIDER=anthropic
# Validation: Starts with sk-ant-
# Obtain from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# [OPTIONAL] Google AI API Key
# Required if LLM_PROVIDER=gemini
# Validation: Alphanumeric string
# Obtain from: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=

# [OPTIONAL] AWS Bedrock region
# Required if LLM_PROVIDER=bedrock
# Validation: AWS region format (e.g., us-east-1)
AWS_BEDROCK_REGION=

# [OPTIONAL] Azure OpenAI endpoint
# Required if LLM_PROVIDER=azure
# Validation: Must start with https://
# Example: https://your-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=

# [OPTIONAL] Azure OpenAI API Key
# Required if LLM_PROVIDER=azure
# Validation: Alphanumeric string
AZURE_OPENAI_API_KEY=

# ------------------------------------------------------------------------------
# BILLING & PAYMENTS (Future - IU-23, IU-24)
# ------------------------------------------------------------------------------

# [OPTIONAL] Stripe secret key
# Required for payment processing
# Validation: Starts with sk_test_ or sk_live_
# Obtain from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# [OPTIONAL] Stripe publishable key
# Used in frontend payment forms
# Validation: Starts with pk_test_ or pk_live_
STRIPE_PUBLISHABLE_KEY=

# [OPTIONAL] Stripe webhook secret
# Used to verify webhook signatures
# Validation: Starts with whsec_
STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# NOTIFICATION PROVIDERS (Future - IU-26)
# ------------------------------------------------------------------------------

# [OPTIONAL] SendGrid API Key
# Required for email notifications
# Validation: Starts with SG.
# Obtain from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# [OPTIONAL] SendGrid sender email
# Verified sender email address
# Validation: Valid email format
SENDGRID_FROM_EMAIL=

# [OPTIONAL] Twilio Account SID
# Required for SMS notifications
# Validation: Starts with AC
# Obtain from: https://console.twilio.com
TWILIO_ACCOUNT_SID=

# [OPTIONAL] Twilio Auth Token
# Required for SMS notifications
# Validation: Alphanumeric string
TWILIO_AUTH_TOKEN=

# [OPTIONAL] Twilio phone number
# Source phone number for SMS
# Validation: E.164 format (e.g., +12025551234)
TWILIO_PHONE_NUMBER=

# [OPTIONAL] Slack webhook URL
# Required for Slack notifications
# Validation: Must start with https://hooks.slack.com/
# Obtain from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ------------------------------------------------------------------------------
# STORAGE PROVIDERS (Future - IU-7 onwards)
# ------------------------------------------------------------------------------

# [OPTIONAL] AWS S3 bucket name
# For file storage and uploads
# Validation: Valid S3 bucket name format
AWS_S3_BUCKET=

# [OPTIONAL] AWS region for S3
# Validation: AWS region format
# Default: us-east-1
AWS_S3_REGION=us-east-1

# [OPTIONAL] AWS access key ID
# Required for S3 access
# Validation: Starts with AKIA
AWS_ACCESS_KEY_ID=

# [OPTIONAL] AWS secret access key
# Required for S3 access
# Validation: Alphanumeric + special chars, 40 chars
AWS_SECRET_ACCESS_KEY=

# ------------------------------------------------------------------------------
# OBSERVABILITY & TELEMETRY (Future - IU-33 onwards)
# ------------------------------------------------------------------------------

# [OPTIONAL] OpenTelemetry exporter endpoint
# OTLP endpoint for traces, metrics, logs
# Validation: Must start with http:// or https://
# Example: http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=

# [OPTIONAL] Service name for telemetry
# Identifies the service in observability platforms
# Validation: Alphanumeric with hyphens/underscores
# Default: axon-flow
OTEL_SERVICE_NAME=axon-flow

# [OPTIONAL] Prometheus metrics port
# Port for Prometheus scraping
# Validation: Integer between 1024-65535
# Default: 9090
PROMETHEUS_PORT=9090

# [OPTIONAL] Grafana API URL
# For programmatic dashboard management
# Validation: Must start with http:// or https://
GRAFANA_API_URL=

# [OPTIONAL] Grafana API key
# For authentication
# Validation: Alphanumeric string
GRAFANA_API_KEY=

# ------------------------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------------------------

# [OPTIONAL] Enable Turborepo remote caching
# Toggle remote cache for builds
# Validation: Must be true or false
# Default: false
ENABLE_REMOTE_CACHE=false

# [OPTIONAL] Enable observability telemetry
# Toggle OpenTelemetry instrumentation
# Validation: Must be true or false
# Default: false
ENABLE_TELEMETRY=false

# [OPTIONAL] Enable BYOK (Bring Your Own Key) encryption
# Allow users to provide their own encryption keys
# Validation: Must be true or false
# Default: false
ENABLE_BYOK=false

# [OPTIONAL] Enable rate limiting
# Apply rate limits to API endpoints
# Validation: Must be true or false
# Default: true
ENABLE_RATE_LIMITING=true

# [OPTIONAL] Enable audit logging
# Log all user actions for compliance
# Validation: Must be true or false
# Default: true
ENABLE_AUDIT_LOGGING=true

# ------------------------------------------------------------------------------
# DEVELOPMENT & DEBUGGING
# ------------------------------------------------------------------------------

# [OPTIONAL] Enable debug mode
# Enables additional logging and tooling
# Validation: Must be true or false
# Default: false (auto-true if NODE_ENV=development)
DEBUG=false

# [OPTIONAL] Pretty print logs
# Format logs with colors and indentation
# Validation: Must be true or false
# Default: true (false in production)
PRETTY_LOGS=true

# [OPTIONAL] Database query logging
# Log all database queries (performance impact)
# Validation: Must be true or false
# Default: false
LOG_DB_QUERIES=false

# ------------------------------------------------------------------------------
# SECURITY & ENCRYPTION
# ------------------------------------------------------------------------------

# [OPTIONAL] Encryption key for BYOK
# Master key for encrypting user-provided keys
# Validation: Minimum 32 characters
# SECURITY: Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# [OPTIONAL] CORS allowed origins
# Comma-separated list of allowed origins
# Validation: Valid URLs or * for all origins
# Default: http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# [OPTIONAL] Rate limit window (milliseconds)
# Time window for rate limiting
# Validation: Positive integer
# Default: 900000 (15 minutes)
RATE_LIMIT_WINDOW=900000

# [OPTIONAL] Rate limit max requests
# Maximum requests per window
# Validation: Positive integer
# Default: 100
RATE_LIMIT_MAX=100

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================
#
# For more information:
#   - See ENV_MANAGEMENT.md for detailed documentation
#   - Run `pnpm validate:env` to verify configuration
#   - Visit project documentation for workspace-specific variables
#
# ==============================================================================
