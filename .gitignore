# ==========================================
# Axon Flow - Security-First .gitignore
# ==========================================

# Build Artifacts
# ==========================================
.turbo/
dist/
build/
out/
.next/
.nuxt/
.cache/
coverage/
*.tsbuildinfo
.docusaurus/

# IDE Files
# ==========================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project

# OS Files
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Dependency Artifacts
# ==========================================
node_modules/
.pnpm-store/
.yarn/
.npm/
bower_components/

# Environment Files - SECURITY CRITICAL
# ==========================================
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
credentials/

# Logs and Temporary Files
# ==========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
pnpm-lock.yaml*
lerna-debug.log*
tmp/
temp/
.temp/
*.tmp
*.temp

# Validation and Report Files
# ==========================================
*validation*.json
*-report.json
*report*.json
.reports/

# Testing
# ==========================================
cypress/videos/
cypress/screenshots/
test-results/
playwright-report/
playwright/.cache/

# Production Files
# ==========================================
*.min.js
*.min.css
*.map

# Database
# ==========================================
*.sqlite
*.sqlite3
*.db
prisma/migrations/dev/

# Docker
# ==========================================
.dockerignore
docker-compose.override.yml

# Monitoring & Profiling
# ==========================================
*.heapsnapshot
*.cpuprofile
.clinic/

# Package Manager Files
# ==========================================
package-lock.json
yarn.lock
!pnpm-lock.yaml

# Miscellaneous
# ==========================================
.history/
.husky/_/
*.bak
*.backup
*.old
.vercel/
.netlify/
.claude/
.cursor/
.serena/
.taskmaster/
CLAUDE.md
docs/personal/

# Platform-Specific
# ==========================================
# Raspberry Pi specific
*.img
*.dtb
/boot/

# Development artifacts
.turbo/
.eslintcache
.stylelintcache
.prettiercache
