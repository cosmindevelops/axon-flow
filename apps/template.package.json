{
  "name": "@axon/app-web-dashboard",
  "private": true,
  "version": "0.1.0",
  "description": "Next.js web dashboard surface aligned with IU-28/IU-29 validation criteria.",
  "keywords": ["axon-flow", "iu-28", "iu-29", "app"],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings=0 .",
    "typecheck": "tsc --build tsconfig.json",
    "test": "pnpm run test:unit && pnpm run test:component",
    "test:unit": "jest --config jest.config.ts --selectProjects unit",
    "test:component": "jest --config jest.config.ts --selectProjects component",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@axon/contracts-sdk": "workspace:*",
    "@axon/logger": "workspace:*",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "typescript": "^5.9.0"
  }
}
