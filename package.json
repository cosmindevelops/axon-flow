{
  "name": "axon-flow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "General-purpose multi-agent automation platform with Hub-centric orchestration for intelligent workflow automation",
  "keywords": [
    "multi-agent",
    "orchestration",
    "automation",
    "workflow",
    "rabbitmq",
    "microservices",
    "turborepo",
    "monorepo",
    "typescript",
    "nestjs",
    "saga-pattern",
    "event-driven"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosmindevelops/axon-flow"
  },
  "homepage": "https://github.com/cosmindevelops/axon-flow#readme",
  "engines": {
    "node": ">=24.6.0",
    "pnpm": ">=10.15.0"
  },
  "engineStrict": true,
  "packageManager": "pnpm@10.15.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/core/*",
    "packages/services/*",
    "packages/agents/*",
    "packages/tooling/*"
  ],
  "scripts": {
    "// Core Development": "===== Core Development ====",
    "dev": "turbo dev",
    "start": "turbo start",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,json,md,yaml,yml}'",
    "// Enhanced Development": "===== Enhanced Development ====",
    "dev:hub": "turbo dev --filter=@axon/hub",
    "test:watch": "turbo test:watch",
    "test:ui": "turbo test:ui",
    "test:coverage": "turbo test -- --coverage",
    "lint:fix": "turbo lint:fix",
    "type-check": "turbo type-check",
    "// Quality & Validation": "===== Quality & Validation ====",
    "verify": "turbo verify",
    "verify:full": "pnpm audit && turbo verify && pnpm validate:all && pnpm health",
    "validate:all": "pnpm validate:env && pnpm validate:pnpm && pnpm validate:deps && pnpm validate:structure && pnpm validate:docs",
    "health": "node tools/scripts/axon-tools.cjs quality health-check",
    "audit": "pnpm audit --audit-level=high",
    "// Workspace Management": "===== Workspace Management ====",
    "clean": "turbo clean && rm -rf node_modules/.cache .turbo",
    "clean:deep": "turbo clean && find . -type d -name 'node_modules' -o -name 'dist' -o -name '.turbo' -o -name '.next' -o -name 'coverage' | xargs rm -rf",
    "reset": "pnpm clean:deep && pnpm install",
    "update:deps": "pnpm update --interactive --latest",
    "// Specialized Operations": "===== Specialized Operations ====",
    "workspace": "pnpm --filter",
    "build:affected": "turbo build --filter='[HEAD^1]'",
    "test:affected": "turbo test --filter='[HEAD^1]'",
    "changeset": "changeset",
    "release": "pnpm verify:full && pnpm changeset:version && pnpm changeset:publish",
    "// Git Hooks": "===== Git Lifecycle ====",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "pre-push": "pnpm verify",
    "// Utilities": "===== Developer Utilities ====",
    "info": "pnpm list --recursive --depth 0",
    "outdated": "pnpm outdated --recursive"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@eslint/js": "^9.33.0",
    "@types/node": "^24.3.0",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-compact": "8.40.0",
    "eslint-scope": "8.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "pino": "^9.9.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.40.0",
    "vitest": "^3.2.4",
    "zod": "^4.0.17"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@babel/core",
        "@babel/preset-env",
        "webpack"
      ]
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix",
      "node tools/scripts/axon-tools.cjs quality test-staged"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ],
    "package.json": [
      "prettier --write",
      "node tools/scripts/axon-tools.cjs validate package-changes"
    ],
    "*.{ts,tsx}": [
      "bash -c 'tsc --noEmit --skipLibCheck'"
    ],
    "turbo.json": [
      "node tools/scripts/axon-tools.cjs turbo validate-config"
    ]
  },
  "dependencies": {
    "pino": "^9.9.0"
  }
}
