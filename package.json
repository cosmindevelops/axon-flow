{
  "name": "axon-flow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Axon Flow monorepo orchestrated with Turborepo and pnpm.",
  "license": "PROPRIETARY",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "clean": "node scripts/maintenance/remove-build-artifacts.js",
    "clean:cache": "node scripts/maintenance/clear-turbo-cache.js",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev": "turbo run dev --parallel",
    "typecheck": "tsc --build tsconfig.json",
    "format": "prettier --cache --write .",
    "format:check": "prettier --cache --check .",
    "validate:env": "node scripts/validate-env.js",
    "check": "pnpm lint && pnpm format:check",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "validate": "pnpm exec tsx scripts/validation/index.ts",
    "benchmark": "pnpm exec tsx scripts/validation/index.ts --mode benchmark"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.37.0",
    "@types/node": "^24.6.2",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^6.1.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "turbo": "2.5.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0"
  }
}
