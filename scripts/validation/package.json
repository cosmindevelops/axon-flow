{
  "name": "@axon/validation",
  "version": "0.1.0",
  "private": true,
  "description": "IU-centric validation system for Axon Flow implementation units",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "validate": "./dist/orchestrator/cli.js"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsc --build --watch",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "validate:example": "node dist/orchestrator/cli.js run --iu 1",
    "validate:all": "node dist/orchestrator/cli.js run --all",
    "scaffold": "tsx templates/scaffold.ts",
    "verify": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.1",
    "date-fns": "^4.1.0",
    "handlebars": "^4.7.8",
    "marked": "^16.3.0",
    "ora": "^8.0.1",
    "table": "^6.8.2",
    "zod": "^3.23.8",
    "semver-regex": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.2",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.37.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}
