{
  "name": "@axon/errors",
  "version": "0.0.0",
  "description": "Error handling and standardized error hierarchy for Axon Flow",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo",
    "dev": "tsup --watch",
    "format": "prettier --write \"src/**/*.ts\" || true",
    "format:check": "prettier --check \"src/**/*.ts\" || true",
    "lint": "eslint src --config ../../../eslint.config.js",
    "lint:fix": "eslint src --fix --config ../../../eslint.config.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@axon/types": "workspace:*"
  },
  "devDependencies": {
    "@axon/typescript-config": "workspace:*"
  }
}
