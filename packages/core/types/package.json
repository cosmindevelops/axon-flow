{
  "name": "@axon/types",
  "version": "0.1.0",
  "description": "Shared TypeScript types and interfaces for Axon Flow",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./platform/node": {
      "types": "./dist/platform/node/index.d.ts",
      "import": "./dist/platform/node/index.mjs",
      "require": "./dist/platform/node/index.js"
    },
    "./platform/browser": {
      "types": "./dist/platform/browser/index.d.ts",
      "import": "./dist/platform/browser/index.mjs",
      "require": "./dist/platform/browser/index.js"
    },
    "./platform/common": {
      "types": "./dist/platform/common/index.d.ts",
      "import": "./dist/platform/common/index.mjs",
      "require": "./dist/platform/common/index.js"
    },
    "./core/*": {
      "types": "./dist/core/*/index.d.ts",
      "import": "./dist/core/*/index.mjs",
      "require": "./dist/core/*/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@vitest/ui": "3.2.4"
  }
}
