{
  "name": "@axon/vitest-config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Centralized Vitest configuration for Axon Flow monorepo",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./base": {
      "types": "./src/base.ts",
      "import": "./src/base.ts"
    }
  },
  "files": [
    "src"
  ],
  "dependencies": {
    "vitest": "^3.2.4",
    "@vitest/ui": "^3.2.4"
  },
  "devDependencies": {
    "@axon/typescript-config": "workspace:*"
  }
}
