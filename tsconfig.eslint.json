{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.mjs",
    "**/*.cjs",
    "*.config.{js,ts,mjs}",
    "eslint.config.js",
    "packages/*/src/**/*",
    "packages/*/tests/**/*",
    "apps/*/src/**/*",
    "apps/*/tests/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "dist",
    "**/dist",
    "build",
    "**/build",
    ".next",
    "**/.next",
    "coverage",
    "**/coverage",
    ".turbo",
    "**/.turbo"
  ]
}
